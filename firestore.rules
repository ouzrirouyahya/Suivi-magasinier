rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net (Default Deny Catch-All)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email != null);
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches("^[a-zA-Z0-9_-]+$");
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && isEmailVerified() && (
        (request.auth.token.email != null && request.auth.token.email.lower() in ['ouzrirouyahya@gmail.com', 'hydro.magasinier@gmail.com']) ||
        (exists(/databases/$(database)/documents/accounts/$(request.auth.uid)) && (get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.role == 'ADMIN' || get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.role == 'SUPER_ADMIN'))
      );
    }

    // Vrai uniquement pour le SUPER_ADMIN strict (pas un ADMIN simple), 
    // utilisé pour les actions réservées exclusivement au niveau le plus 
    // élevé (gestion des droits des autres admins notamment)
    function isSuperAdmin() {
      return isSignedIn() && isEmailVerified() && (
        (request.auth.token.email != null && request.auth.token.email.lower() in ['ouzrirouyahya@gmail.com', 'hydro.magasinier@gmail.com']) ||
        (exists(/databases/$(database)/documents/accounts/$(request.auth.uid)) && get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.role == 'SUPER_ADMIN')
      );
    }

    // Vrai si l'utilisateur est ADMIN avec canWrite explicitement à true
    function isAdminWithWriteAccess() {
      return isActive() && exists(/databases/$(database)/documents/accounts/$(request.auth.uid))
        && get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.role == 'ADMIN'
        && get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.get('canWrite', false) == true;
    }

    function isMaintenanceLocked() {
      return exists(/databases/$(database)/documents/metadata/system_config) && get(/databases/$(database)/documents/metadata/system_config).data.maintenanceMode == true;
    }

    function isActive() {
      return isEmailVerified() && (
        (request.auth.token.email != null && request.auth.token.email.lower() in ['ouzrirouyahya@gmail.com', 'hydro.magasinier@gmail.com']) ||
        (exists(/databases/$(database)/documents/accounts/$(request.auth.uid)) && get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.active == true)
      );
    }

    function isAnyRole(roles) {
      return isActive() && (
        (exists(/databases/$(database)/documents/accounts/$(request.auth.uid)) && get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.role in roles) ||
        (exists(/databases/$(database)/documents/accounts/$(request.auth.uid)) && get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.role == 'SUPER_ADMIN')
      );
    }

    // Renvoie le site assigné de l'utilisateur connecté (ou null)
    function userAssignedSite() {
      return exists(/databases/$(database)/documents/accounts/$(request.auth.uid))
        ? get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.get('assignedSite', null)
        : null;
    }

    // Vrai si l'utilisateur est ADMIN/SUPER_ADMIN (accès tous sites) 
    // OU si le site du document concerné correspond exactement à son 
    // site assigné
    function canWriteOnSite(allowedRoles, docSite) {
      return canWrite(allowedRoles) && (
        isAdmin() || userAssignedSite() == docSite
      );
    }

    // Variante pour les transferts, qui impliquent deux sites 
    // (source et destination) : le magasinier doit être assigné à 
    // l'un des deux sites concernés par l'opération
    function canWriteOnTransfertSites(allowedRoles, sourceSite, targetSite) {
      return canWrite(allowedRoles) && (
        isAdmin() || userAssignedSite() == sourceSite || userAssignedSite() == targetSite
      );
    }

    // Vrai si l'utilisateur est connecté, actif, ET soit ADMIN/SUPER_ADMIN 
    // (accès total), soit MAGASINIER/LECTURE_SEULE assigné exactement à docSite
    function canReadSite(docSite) {
      return isActive() && (
        isAdmin() || userAssignedSite() == docSite
      );
    }

    // Variante pour les transferts (deux sites concernés)
    function canReadTransfertSites(sourceSite, targetSite) {
      return isActive() && (
        isAdmin() || userAssignedSite() == sourceSite || userAssignedSite() == targetSite
      );
    }

    // Pour les collections globales sans notion de site (accessible à 
    // tout utilisateur actif, peu importe son chantier)
    function canReadIfActive() {
      return isActive();
    }

    // System-wide write condition with Maintenance Mode protection
    function canWrite(allowedRoles) {
      return isMaintenanceLocked() 
        ? (isSuperAdmin() || (('ADMIN' in allowedRoles) && isAdminWithWriteAccess()))
        : (
          isSuperAdmin() ||
          (('ADMIN' in allowedRoles) && isAdminWithWriteAccess()) ||
          (('MAGASINIER' in allowedRoles) && isActive() && exists(/databases/$(database)/documents/accounts/$(request.auth.uid)) && get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.role == 'MAGASINIER' && get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.role in allowedRoles)
        );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidArticle(data) {
      return data.keys().hasAll(['id', 'site', 'ref', 'designation', 'type', 'quantity', 'minStock', 'active'])
        && data.keys().size() <= 25
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.site is string && data.site.size() > 0 && data.site.size() <= 64
        && data.ref is string && data.ref.size() > 0 && data.ref.size() <= 128
        && data.designation is string && data.designation.size() > 0 && data.designation.size() <= 512
        && data.type is string && data.type.size() > 0 && data.type.size() <= 64
        && data.quantity is number && data.quantity >= 0 && data.quantity <= 1000000000
        && data.minStock is number && data.minStock >= 0 && data.minStock <= 1000000000
        && data.active is bool
        && data.get('category', '') is string && data.get('category', '').size() <= 128
        && data.get('unit', '') is string && data.get('unit', '').size() <= 32
        && data.get('price', 0) is number && data.get('price', 0) >= 0
        && data.get('location', '') is string && data.get('location', '').size() <= 128
        && data.get('notes', '') is string && data.get('notes', '').size() <= 2048
        && data.get('compatibility', '') is string && data.get('compatibility', '').size() <= 2048
        && data.get('criticality', '') is string && data.get('criticality', '').size() <= 64
        && data.get('lastInventoryDate', '') is string && data.get('lastInventoryDate', '').size() <= 64
        && data.get('subComponent', '') is string && data.get('subComponent', '').size() <= 128
        && data.get('component', '') is string && data.get('component', '').size() <= 128
        && data.get('subCategory', '') is string && data.get('subCategory', '').size() <= 128
        && data.get('functionalCategory', '') is string && data.get('functionalCategory', '').size() <= 128;
    }

    function isValidMouvement(data) {
      return data.keys().hasAll(['id', 'site', 'date', 'type', 'items', 'status'])
        && data.keys().size() <= 25
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.site is string && data.site.size() > 0 && data.site.size() <= 64
        && data.date is string && data.date.size() > 0 && data.date.size() <= 128
        && data.type is string && data.type in ['ENTREE', 'SORTIE', 'TRANSFERT_OUT', 'TRANSFERT_IN', 'AJUSTEMENT', 'RETOUR']
        && data.status is string && data.status in ['BROUILLON', 'VALIDE', 'EN_TRANSIT', 'COMPLETE']
        && data.items is list && data.items.size() > 0 && data.items.size() <= 100
        && data.get('reference', '') is string && data.get('reference', '').size() <= 128
        && data.get('demandeur', '') is string && data.get('demandeur', '').size() <= 128
        && data.get('mecanicien', '') is string && data.get('mecanicien', '').size() <= 128
        && data.get('service', '') is string && data.get('service', '').size() <= 128
        && data.get('motif', '') is string && data.get('motif', '').size() <= 512
        && data.get('notes', '') is string && data.get('notes', '').size() <= 2048;
    }

    function isValidTransfert(data) {
      return data.keys().hasAll(['id', 'sourceSite', 'targetSite', 'dateEnvoi', 'reference', 'items', 'status'])
        && data.keys().size() <= 32
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.sourceSite is string && data.sourceSite.size() > 0 && data.sourceSite.size() <= 64
        && data.targetSite is string && data.targetSite.size() > 0 && data.targetSite.size() <= 64
        && data.sourceSite != data.targetSite
        && data.reference is string && data.reference.size() > 0 && data.reference.size() <= 128
        && data.status is string && data.status in ['PENDING_APPROVAL', 'IN_TRANSIT', 'RECEIVED', 'DISPUTED', 'CLOSED', 'EN_TRANSIT', 'RECU', 'LITIGE']
        && data.items is list && data.items.size() > 0 && data.items.size() <= 100
        && data.get('expediteur', '') is string && data.get('expediteur', '').size() <= 128
        && (!data.keys().contains('dateReception') || data.dateReception is string)
        && (!data.keys().contains('recepteur') || data.recepteur is string)
        && (!data.keys().contains('receivedItems') || data.receivedItems is list)
        && (!data.keys().contains('disputeReason') || data.disputeReason is string);
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['id', 'email', 'name', 'role', 'active'])
        && data.keys().size() <= 16
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.email is string && data.email.size() > 0 && data.email.size() <= 256
        && data.name is string && data.name.size() > 0 && data.name.size() <= 256
        && data.role is string && data.role in ['SUPER_ADMIN', 'ADMIN', 'MAGASINIER']
        && data.active is bool
        && (!data.keys().contains('canWrite') || data.canWrite is bool)
        && data.get('createdAt', '') is string && data.get('createdAt', '').size() <= 128
        && (!data.keys().contains('status') || data.status in ['PENDING', 'APPROVED', 'REJECTED'])
        && (!data.keys().contains('requestedRole') || data.requestedRole in ['ADMIN', 'MAGASINIER'])
        && (!data.keys().contains('assignedSite') || data.assignedSite == null || data.assignedSite is string)
        && (!data.keys().contains('requestedSite') || data.requestedSite == null || data.requestedSite is string);
    }

    function isValidAuditLog(data) {
      return data.keys().hasAll(['id', 'timestamp', 'userEmail', 'site', 'action', 'details'])
        && data.keys().size() <= 15
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.userEmail is string && data.userEmail.size() > 0 && data.userEmail.size() <= 256
        && data.site is string && data.site.size() > 0 && data.site.size() <= 64
        && data.action is string && data.action.size() > 0 && data.action.size() <= 128
        && data.details is string && data.details.size() <= 4096
        && (data.timestamp is string || data.timestamp is timestamp);
    }

    function isValidInventaire(data) {
      return data.keys().hasAll(['id', 'site', 'date', 'type', 'status', 'items'])
        && data.keys().size() <= 10
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.site is string && data.site.size() > 0 && data.site.size() <= 64
        && data.status is string && data.status in ['OUVERT', 'VALIDE']
        && data.items is list;
    }

    function isValidDistribution(data) {
      return data.keys().hasAll(['id', 'site', 'agentName', 'service', 'articleId', 'date', 'quantity'])
        && data.keys().size() <= 10
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.site is string && data.site.size() > 0 && data.site.size() <= 64
        && data.agentName is string && data.agentName.size() > 0
        && data.quantity is number;
    }

    function isValidPurchaseRequest(data) {
      return data.keys().hasAll(['id', 'site', 'date', 'status', 'items', 'createdBy'])
        && data.keys().size() <= 10
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.site is string && data.site.size() > 0 && data.site.size() <= 64
        && data.status is string && data.status in ['BROUILLON', 'ENVOYE', 'VALIDE', 'COMMANDE', 'RECU']
        && data.items is list;
    }

    function isValidAnomalyReport(data) {
      return data.keys().hasAll(['id', 'site', 'timestamp', 'type', 'severity', 'description', 'status'])
        && data.keys().size() <= 12
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.site is string && data.site.size() > 0 && data.site.size() <= 64
        && data.status is string && data.status in ['NEW', 'INVESTIGATING', 'RESOLVED', 'DISMISSED']
        && data.description is string;
    }

    function isValidMaintenanceLog(data) {
      return data.keys().hasAll(['id', 'machineId', 'machineType', 'date', 'type', 'description', 'partsUsed', 'performer'])
        && data.keys().size() <= 12
        && data.id is string
        && data.machineId is string
        && data.partsUsed is list;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['id', 'siteId', 'type', 'category', 'message', 'timestamp', 'isRead', 'severity', 'status'])
        && data.keys().size() <= 15
        && data.id is string;
    }

    function isValidDeletionRequest(data) {
      return data.keys().hasAll(['id', 'articleIds', 'articleRefs', 'articleDesignations', 'site', 'requestedBy', 'requestedAt', 'status'])
        && data.keys().size() <= 12
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.articleIds is list && data.articleIds.size() > 0 && data.articleIds.size() <= 200
        && data.status is string && data.status in ['PENDING_APPROVAL', 'APPROVED', 'REJECTED'];
    }

    function isValidReport(data) {
      return data.keys().hasAll(['site', 'type', 'generatedAt', 'data'])
        && data.keys().size() <= 10
        && data.site is string && data.site.size() > 0 && data.site.size() <= 64
        && data.type is string && data.type.size() > 0 && data.type.size() <= 128
        && data.generatedAt is string && data.generatedAt.size() > 0 && data.generatedAt.size() <= 128;
    }

    function isValidHydrominesCatalog(data) {
      return data.keys().hasAll(['id', 'reference', 'designation', 'suggestedType', 'functionalCategory', 'unit', 'sourceCatalog', 'equipmentFamily', 'status', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 15
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.reference is string && data.reference.size() > 0 && data.reference.size() <= 128
        && data.designation is string && data.designation.size() > 0 && data.designation.size() <= 512
        && data.suggestedType is string && data.suggestedType.size() > 0
        && data.functionalCategory is string && data.functionalCategory.size() > 0
        && data.unit is string && data.unit.size() > 0
        && data.sourceCatalog is string && data.sourceCatalog.size() > 0
        && data.equipmentFamily is string && data.equipmentFamily in ['ST2G', 'ST2D', 'T23', 'T28', 'EPI', 'CONSOMMABLES', 'AUTRE']
        && data.status is string && data.status in ['ACTIF', 'INACTIF']
        && data.createdAt is string
        && data.updatedAt is string
        && (!data.keys().contains('isHydrominesCritical') || data.isHydrominesCritical is bool);
    }

    // --- Match Rules Blocks ---

    // Master Catalog Rules
    match /catalog/{id} {
      allow read: if canReadIfActive();
      allow write: if canWrite(['ADMIN', 'MAGASINIER']) && isValidId(id);
    }
    match /hydromines_catalog/{id} {
      allow read: if canReadIfActive();
      allow write: if canWrite(['ADMIN', 'MAGASINIER']) && isValidId(id) && isValidHydrominesCatalog(incoming());
    }
    match /metadata/{id} {
      allow read: if true;
      allow write: if isAdmin() && isValidId(id); // System admins bypass canWrite during lockdown
    }
    match /engins/{id} {
      allow read: if canReadIfActive();
      allow write: if canWrite(['ADMIN', 'MAGASINIER']) && isValidId(id);
    }
    match /perfos/{id} {
      allow read: if canReadIfActive();
      allow write: if canWrite(['ADMIN', 'MAGASINIER']) && isValidId(id);
    }
    match /agents/{id} {
      allow read: if canReadIfActive();
      allow write: if canWrite(['ADMIN', 'MAGASINIER']) && isValidId(id);
    }

    // Stocks/Articles: Protected from non-magasiniers and arbitrary value-poisoning
    match /articles/{articleId} {
      allow read: if canReadSite(resource.data.site);
      allow create: if canWriteOnSite(['ADMIN', 'MAGASINIER'], incoming().site) 
                    && isValidId(articleId) && isValidArticle(incoming());
      allow update: if canWriteOnSite(['ADMIN', 'MAGASINIER'], existing().site) 
                    && canWriteOnSite(['ADMIN', 'MAGASINIER'], incoming().site)
                    && isValidId(articleId) && isValidArticle(incoming());
      allow delete: if canWrite(['ADMIN']) && isValidId(articleId);
    }

    // accounts Management (Zero self promotion RBAC gates)
    match /accounts/{userId} {
      allow get: if isSignedIn();
      allow list: if isActive();
      allow create: if isSignedIn() && isValidId(userId) && isOwner(userId) && isValidAccount(incoming()) && (
        isSuperAdmin() || 
        // Cas particulier des comptes administrateurs racine créés directement actifs
        (incoming().active == true && request.auth.token.email != null && request.auth.token.email.lower() in ['ouzrirouyahya@gmail.com', 'hydro.magasinier@gmail.com']) ||
        // Tout utilisateur connecté peut créer sa demande d'accès en attente d'approbation
        (incoming().active == false && incoming().status == 'PENDING')
      );
      allow update: if isValidId(userId) && isSignedIn() && (
        isSuperAdmin() || (
          isOwner(userId)
          && incoming().role == existing().role
          && incoming().active == existing().active
          // L'utilisateur ne peut pas modifier lui-même son statut d'approbation s'il est déjà défini
          && (incoming().status == existing().status || (!existing().keys().contains('status') && incoming().status == 'PENDING'))
          && (!incoming().keys().contains('canWrite') || incoming().canWrite == existing().get('canWrite', false))
          && isValidAccount(incoming())
        )
      );
    }

    // Secure Transferts
    match /transferts/{id} {
      allow read: if canReadTransfertSites(resource.data.sourceSite, resource.data.targetSite);
      allow create: if canWriteOnTransfertSites(['ADMIN', 'MAGASINIER'], incoming().sourceSite, incoming().targetSite) 
                    && isValidId(id) && isValidTransfert(incoming());
      allow update: if isValidId(id) && canWriteOnTransfertSites(['ADMIN', 'MAGASINIER'], existing().sourceSite, existing().targetSite) && (
        isAdmin() || (
          existing().status == 'EN_TRANSIT' &&
          incoming().status == 'RECU' &&
          incoming().sourceSite == existing().sourceSite &&
          incoming().targetSite == existing().targetSite &&
          incoming().reference == existing().reference
        )
      );
      allow delete: if canWrite(['ADMIN']) && isValidId(id);
    }

    // Transactional Movements: Append-only, never modifiable except by ADMIN, never deletable
    match /mouvements/{id} {
      allow read: if canReadSite(resource.data.site);
      allow create: if canWriteOnSite(['ADMIN', 'MAGASINIER', 'MAINTENANCE'], incoming().site) 
                    && isValidId(id) && isValidMouvement(incoming());
      allow update: if canWrite(['ADMIN']) && isValidId(id) && isValidMouvement(incoming());
      allow delete: if false;
    }

    // Audit logs: Strictly append-only. Immutable once recorded.
    match /auditLogs/{id} {
      allow read: if canReadIfActive();
      allow create: if canReadIfActive() && isValidId(id) && isValidAuditLog(incoming());
      allow update, delete: if false;
    }

    // Reports: Generated analysis storage
    match /reports/{reportId} {
      allow read: if canReadIfActive();
      allow create: if canReadIfActive() && isValidId(reportId) && isValidReport(incoming());
      allow update, delete: if isAdmin();
    }

    // Deletion requests: submitted by magaziniers, approved/rejected by admins
    match /deletionRequests/{id} {
      allow read: if canReadIfActive();
      allow create: if canWrite(['ADMIN', 'MAGASINIER']) && isValidId(id) && isValidDeletionRequest(incoming());
      allow update: if isAdmin() && isValidId(id);
      allow delete: if isAdmin();
    }

    // Inventaires
    match /inventaires/{id} {
      allow read: if canReadSite(resource.data.site);
      allow create: if canWriteOnSite(['ADMIN', 'MAGASINIER'], incoming().site) 
                    && isValidId(id) && isValidInventaire(incoming());
      allow update: if canWriteOnSite(['ADMIN', 'MAGASINIER'], existing().site)
                    && canWriteOnSite(['ADMIN', 'MAGASINIER'], incoming().site)
                    && isValidId(id) && isValidInventaire(incoming());
      allow delete: if isAdmin();
    }

    // Distributions
    match /distributions/{id} {
      allow read: if canReadSite(resource.data.site);
      allow create: if canWriteOnSite(['ADMIN', 'MAGASINIER'], incoming().site) 
                    && isValidId(id) && isValidDistribution(incoming());
      allow update: if canWriteOnSite(['ADMIN', 'MAGASINIER'], existing().site)
                    && canWriteOnSite(['ADMIN', 'MAGASINIER'], incoming().site)
                    && isValidId(id) && isValidDistribution(incoming());
      allow delete: if isAdmin();
    }

    // Purchase Requests
    match /purchaseRequests/{id} {
      allow read: if canReadSite(resource.data.site);
      allow create: if canWriteOnSite(['ADMIN', 'MAGASINIER'], incoming().site) 
                    && isValidId(id) && isValidPurchaseRequest(incoming());
      allow update: if canWriteOnSite(['ADMIN', 'MAGASINIER'], existing().site)
                    && canWriteOnSite(['ADMIN', 'MAGASINIER'], incoming().site)
                    && isValidId(id) && isValidPurchaseRequest(incoming());
      allow delete: if isAdmin();
    }

    // Anomaly Reports
    match /anomalyReports/{id} {
      allow read: if canReadIfActive();
      allow create: if canReadIfActive() && isValidId(id) && isValidAnomalyReport(incoming());
      allow update: if canReadIfActive() && isValidId(id) && isValidAnomalyReport(incoming());
      allow delete: if isAdmin();
    }

    // Maintenance Logs
    match /maintenanceLogs/{id} {
      allow read: if canReadIfActive();
      allow create: if canWrite(['ADMIN', 'MAGASINIER']) && isValidId(id) && isValidMaintenanceLog(incoming());
      allow update: if canWrite(['ADMIN', 'MAGASINIER']) && isValidId(id) && isValidMaintenanceLog(incoming());
      allow delete: if isAdmin();
    }

    // Notifications
    match /notifications/{id} {
      allow read: if canReadIfActive();
      allow create: if canReadIfActive() && isValidId(id) && isValidNotification(incoming());
      allow update: if canReadIfActive() && isValidId(id);
      allow delete: if isAdmin() && isValidId(id);
    }

    // Price History Logs
    match /priceHistory/{id} {
      allow read: if canReadIfActive();
      allow create: if canWrite(['ADMIN', 'MAGASINIER']) && isValidId(id);
      allow update, delete: if isAdmin();
    }

    // Replacement Requests
    match /replacementRequests/{id} {
      allow read: if isActive() && (
        isAdmin() || 
        (request.auth.token.email != null && request.auth.token.email == resource.data.userEmail) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == resource.data.userEmail.lower()) ||
        getUserEmail() == resource.data.userEmail || 
        getUserEmail().lower() == resource.data.userEmail.lower()
      );
      allow create: if isActive() && isValidId(id) && (
        (request.auth.token.email != null && request.auth.token.email == request.resource.data.userEmail) ||
        getUserEmail() == request.resource.data.userEmail
      );
      allow update: if isActive() && (
        isAdmin() || (
          ((request.auth.token.email != null && request.auth.token.email == resource.data.userEmail) || getUserEmail() == resource.data.userEmail) && 
          request.resource.data.userEmail == resource.data.userEmail
        )
      );
      allow delete: if isAdmin();
    }

    // =========================================================================
    // PHASE 1 — RÈGLES FIRESTORE : MESSAGERIE & NOTIFICATIONS BANNIÈRES (CORRIGÉES)
    // =========================================================================

    // Helper function to safely get user email with database fallback
    function getUserEmail() {
      return request.auth != null && request.auth.token != null && request.auth.token.email != null
        ? request.auth.token.email
        : (request.auth != null && exists(/databases/$(database)/documents/accounts/$(request.auth.uid))
            ? get(/databases/$(database)/documents/accounts/$(request.auth.uid)).data.email
            : null);
    }

    // --- COLLECTION : messages & system_messages ---
    match /messages/{messageId} {
      allow read: if canReadIfActive();

      allow create: if isActive() &&
        getUserEmail() == request.resource.data.senderId &&
        request.resource.data.createdBy == getUserEmail() &&
        request.resource.data.status == 'ACTIVE';

      allow update: if isActive() &&
        (getUserEmail() == resource.data.senderId || isAdmin()) &&
        request.resource.data.status in ['ACTIVE', 'DELETED_BY_SENDER'];

      allow delete: if isSuperAdmin();
    }

    match /system_messages/{messageId} {
      allow read: if canReadIfActive();

      allow create: if isActive() &&
        getUserEmail() == request.resource.data.senderId &&
        request.resource.data.createdBy == getUserEmail() &&
        request.resource.data.status == 'ACTIVE';

      allow update: if isActive() &&
        (getUserEmail() == resource.data.senderId || isAdmin()) &&
        request.resource.data.status in ['ACTIVE', 'DELETED_BY_SENDER'];

      allow delete: if isSuperAdmin();
    }

    // --- COLLECTION : userInbox & inbox_items ---
    match /userInbox/{userId}/messages/{messageId} {
      allow read: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == userId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == userId.lower()) ||
        getUserEmail() == userId ||
        getUserEmail().lower() == userId.lower()
      );

      allow create: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == request.resource.data.senderId) ||
        getUserEmail() == request.resource.data.senderId
      ) && request.resource.data.userId == userId;

      allow update: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == userId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == userId.lower()) ||
        getUserEmail() == userId ||
        getUserEmail().lower() == userId.lower() ||
        isAdmin()
      ) && request.resource.data.userId == userId;

      allow delete: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == userId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == userId.lower()) ||
        getUserEmail() == userId ||
        getUserEmail().lower() == userId.lower()
      );
    }

    match /inbox_items/{itemId} {
      allow read: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == resource.data.userId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == resource.data.userId.lower()) ||
        getUserEmail() == resource.data.userId ||
        getUserEmail().lower() == resource.data.userId.lower()
      );

      allow create: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == request.resource.data.senderId) ||
        getUserEmail() == request.resource.data.senderId
      );

      allow update: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == resource.data.userId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == resource.data.userId.lower()) ||
        getUserEmail() == resource.data.userId ||
        getUserEmail().lower() == resource.data.userId.lower() ||
        isAdmin()
      );

      allow delete: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == resource.data.userId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == resource.data.userId.lower()) ||
        getUserEmail() == resource.data.userId ||
        getUserEmail().lower() == resource.data.userId.lower()
      );
    }

    // --- COLLECTION : messageDrafts & message_drafts ---
    match /messageDrafts/{draftId} {
      allow read: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == resource.data.senderId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == resource.data.senderId.lower()) ||
        getUserEmail() == resource.data.senderId ||
        getUserEmail().lower() == resource.data.senderId.lower()
      );

      allow create, update: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == request.resource.data.senderId) ||
        getUserEmail() == request.resource.data.senderId
      );

      allow delete: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == resource.data.senderId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == resource.data.senderId.lower()) ||
        getUserEmail() == resource.data.senderId ||
        getUserEmail().lower() == resource.data.senderId.lower()
      );
    }

    match /message_drafts/{draftId} {
      allow read: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == resource.data.senderId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == resource.data.senderId.lower()) ||
        getUserEmail() == resource.data.senderId ||
        getUserEmail().lower() == resource.data.senderId.lower()
      );

      allow create, update: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == request.resource.data.senderId) ||
        getUserEmail() == request.resource.data.senderId
      );

      allow delete: if isActive() && (
        (request.auth.token.email != null && request.auth.token.email == resource.data.senderId) ||
        (request.auth.token.email != null && request.auth.token.email.lower() == resource.data.senderId.lower()) ||
        getUserEmail() == resource.data.senderId ||
        getUserEmail().lower() == resource.data.senderId.lower()
      );
    }

    // --- COLLECTION : messageTelemetry & telemetry_events ---
    match /messageTelemetry/{eventId} {
      allow read: if isAdmin();

      allow create: if isActive() &&
        getUserEmail() == request.resource.data.userId;

      allow update, delete: if false;
    }

    match /telemetry_events/{eventId} {
      allow read: if isAdmin();

      allow create: if isActive() &&
        getUserEmail() == request.resource.data.userId;

      allow update, delete: if false;
    }

    // --- COLLECTION : bannerNotifications & banner_notifications ---
    match /bannerNotifications/{bannerId} {
      allow read: if canReadIfActive();

      allow create: if isAdmin() &&
        getUserEmail() == request.resource.data.createdBy;

      allow update: if isAdmin();

      allow delete: if isSuperAdmin();
    }

    match /banner_notifications/{bannerId} {
      allow read: if canReadIfActive();

      allow create: if isAdmin() &&
        getUserEmail() == request.resource.data.createdBy;

      allow update: if isAdmin();

      allow delete: if isSuperAdmin();
    }

    // --- COLLECTION : bannerViews & banner_views ---
    match /bannerViews/{viewId} {
      allow read: if isActive() && (
        getUserEmail() == resource.data.userId ||
        getUserEmail().lower() == resource.data.userId.lower() ||
        isAdmin()
      );

      allow create: if isActive() &&
        getUserEmail() == request.resource.data.userId;

      allow update: if isActive() &&
        getUserEmail() == request.resource.data.userId;

      allow delete: if false;
    }

    match /banner_views/{viewId} {
      allow read: if isActive() && (
        getUserEmail() == resource.data.userId ||
        getUserEmail().lower() == resource.data.userId.lower() ||
        isAdmin()
      );

      allow create: if isActive() &&
        getUserEmail() == request.resource.data.userId;

      allow update: if isActive() &&
        getUserEmail() == request.resource.data.userId;

      allow delete: if false;
    }

    // --- COLLECTION : messageAnalytics & message_analytics ---
    match /messageAnalytics/{messageId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /message_analytics/{messageId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if isSuperAdmin();
    }
  }
}
