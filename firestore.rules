rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      let path = /databases/$(database)/documents/accounts/$(request.auth.uid);
      return isSignedIn() && (
        request.auth.token.email in ['ouzrirouyahya@gmail.com', 'hydro.magasinier@gmail.com'] ||
        (exists(path) && get(path).data.role == 'ADMIN')
      );
    }

    function isActive() {
      let path = /databases/$(database)/documents/accounts/$(request.auth.uid);
      return isSignedIn() && (
        request.auth.token.email in ['ouzrirouyahya@gmail.com', 'hydro.magasinier@gmail.com'] ||
        (exists(path) && get(path).data.active == true)
      );
    }

    // Public/Metadata collections: Read by any signed-in user
    match /catalog/{id} { allow read: if isSignedIn(); allow write: if isAdmin() && isValidId(id); }
    match /metadata/{id} { allow read: if isSignedIn(); allow write: if isAdmin() && isValidId(id); }
    match /engins/{id} { allow read: if isSignedIn(); allow write: if isAdmin() && isValidId(id); }
    match /perfos/{id} { allow read: if isSignedIn(); allow write: if isAdmin() && isValidId(id); }
    match /agents/{id} { allow read: if isSignedIn(); allow write: if isAdmin() && isValidId(id); }

    // Articles: Read by all active users, write strictly by active
    match /articles/{articleId} {
      allow read: if isActive();
      allow write: if isActive() && isValidId(articleId);
    }

    // Mouvements: Read by active, write by active
    match /mouvements/{id} {
      allow read: if isActive();
      allow create: if isActive();
      allow update: if isAdmin();
    }

    // Accounts: 
    // - Anyone signed in can get (needed for login check)
    // - Create for self-provisioning
    // - List restricted to ADMIN
    // - Update restricted to owner (no role change) or admin
    match /accounts/{userId} {
      allow get, create: if isSignedIn() && isValidId(userId);
      allow list: if isAdmin();
      allow update: if (isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role)) && isValidId(userId);
    }

    // Others
    match /auditLogs/{id} { allow read: if isSignedIn(); allow create: if isSignedIn(); }
    match /transferts/{id} { allow read: if isSignedIn(); allow write: if isActive(); }
    match /inventaires/{id} { allow read, write: if isActive(); }
    match /distributions/{id} { allow read, write: if isActive(); }
    match /purchaseRequests/{id} { allow read, write: if isActive(); }
    match /anomalyReports/{id} { allow read, write: if isActive(); }
  }
}

