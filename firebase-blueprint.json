{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "Un article en stock sur un site spécifique",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "site": { "type": "string" },
        "ref": { "type": "string" },
        "designation": { "type": "string" },
        "type": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "quantity": { "type": "number" },
        "minStock": { "type": "number" },
        "price": { "type": "number" },
        "active": { "type": "boolean" },
        "lastInventoryDate": { "type": "string" }
      },
      "required": ["id", "site", "ref", "designation", "quantity"]
    },
    "Mouvement": {
      "title": "Mouvement",
      "description": "Une transaction de stock (Entrée, Sortie, Transfert)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "site": { "type": "string" },
        "date": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["id", "site", "date", "type", "status"]
    },
    "UserAccount": {
      "title": "User Account",
      "description": "Profil utilisateur et droits d'accès",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string" },
        "active": { "type": "boolean" }
      },
      "required": ["id", "email", "role"]
    },
    "AIReport": {
      "title": "AI Report",
      "description": "Rapport d'analyse IA persistant (Quotidien, Hebdo, etc.)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "site": { "type": "string" },
        "type": { "type": "string", "enum": ["DAILY", "WEEKLY", "MONTHLY", "QUARTERLY", "ANNUAL"] },
        "generatedAt": { "type": "string" },
        "data": { "type": "object" },
        "stats": { "type": "object" }
      },
      "required": ["id", "site", "type", "generatedAt", "data"]
    },
    "DeletionRequest": {
      "title": "DeletionRequest",
      "description": "Demande de suppression d'articles soumise par un magasinier pour validation admin",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "articleIds": { "type": "array" },
        "articleRefs": { "type": "array" },
        "articleDesignations": { "type": "array" },
        "site": { "type": "string" },
        "requestedBy": { "type": "string" },
        "requestedAt": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["id", "articleIds", "site", "requestedBy", "requestedAt", "status"]
    }
  },
  "firestore": {
    "/deletionRequests/{id}": {
      "schema": "DeletionRequest",
      "description": "Demandes de suppression d'articles soumises à la validation administrative"
    },
    "/reports/{reportId}": {
      "schema": "AIReport",
      "description": "Stockage des analyses IA générées automatiquement"
    },
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Collection principale des stocks"
    },
    "/mouvements/{mouvementId}": {
      "schema": "Mouvement",
      "description": "Historique des flux"
    },
    "/accounts/{userId}": {
      "schema": "UserAccount",
      "description": "Configuration des accès"
    },
    "/viewer_sessions/{sessionId}": {
      "schema": "object",
      "description": "Sessions en temps réel des utilisateurs du Viewer"
    },
    "/viewer_activity/{activityId}": {
      "schema": "object",
      "description": "Activités et navigation des utilisateurs du Viewer"
    },
    "/auditLogs/{logId}": {
      "schema": "object",
      "description": "Journaux d'audit système"
    },
    "/config/master": {
      "schema": "object",
      "description": "Paramètres globaux (Engins, Perfos, etc.)"
    }
  }
}
